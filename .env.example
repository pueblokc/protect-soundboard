# Copy to .env (dev) or set these in your service manager's environment (prod).
# NEVER commit a real .env — it is git-ignored.

# Your UniFi Protect NVR / console (Cloud Key, UNVR, Dream Machine, etc.)
PROTECT_NVR_HOST=192.168.1.100

# A Protect LOCAL account (created in OS Settings -> Admins on the console).
# Recommend a DEDICATED, minimal-permission local admin for this app rather than
# your primary account. The talkback + private-API calls need admin on the
# speaker/siren devices.
PROTECT_NVR_USER=soundboard
PROTECT_NVR_PASS=changeme

# Optional: premium TTS voice via ElevenLabs. Leave blank to use UniFi's free
# built-in text-to-speech instead (plainer voice, but no account/quota).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Path to ffmpeg if it is not on PATH (talkback transcodes audio through it).
# FFMPEG=ffmpeg
